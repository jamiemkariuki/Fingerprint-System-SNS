# Fingerprint System SNS - Local Development & Testing
# Run tests locally without external dependencies

# Server Configuration
FLASK_HOST=127.0.0.1
FLASK_PORT=8080
FLASK_DEBUG=true

# Test Database
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=fpsnsdb_test

# Test Security Keys
SECRET_KEY=test-secret-key-for-development-only
FINGERPRINT_API_KEY=test-api-key-12345
JWT_SECRET_KEY=test-jwt-secret-12345

# Mock Scanner (set to 1 to use mock scanner)
MOCK_SCANNER=1