# Flask Configuration
# SECURITY: Generate a new SECRET_KEY for production: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me-in-production
FLASK_HOST=0.0.0.0
FLASK_PORT=80
FLASK_DEBUG=false
LOG_LEVEL=INFO

# Database Configuration
# SECURITY: Use strong passwords and never commit production credentials
# For MySQL (local development):
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=change-me-in-production
DB_NAME=fpsnsdb
DB_POOL_SIZE=5

# For PostgreSQL/NeonDB (production):
# USE_POSTGRES=true
# DATABASE_URL=postgresql://user:pass@host.neon.tech/dbname?sslmode=require
# (DATABASE_URL takes precedence over individual DB_* settings)

# Cookie Configuration
# SECURITY: Set SESSION_COOKIE_SECURE=true in production when using HTTPS
SESSION_COOKIE_SECURE=false
SESSION_COOKIE_SAMESITE=Lax

# Email Configuration
# SECURITY: Do not commit production SMTP credentials
SMTP_HOST=smtp.office365.com
SMTP_PORT=587
SMTP_USERNAME=change-me-in-production
SMTP_PASSWORD=change-me-in-production

# Fingerprint API Configuration
# SECURITY: Generate strong keys for production
FINGERPRINT_API_KEY=change-me-in-production
JWT_SECRET_KEY=change-me-in-production
