# NeonDB Configuration (choose one)

# Option 1: Full connection string
NEON_DB_URL=postgres://username:password@host.neon.tech/database

# Option 2: Individual components
# NEON_HOST=your-host.neon.tech
# NEON_USER=your-username
# NEON_PASS=your-password
# NEON_DB=your-database
# NEON_SSL=true

# Scanner Configuration (optional)
# FP_USE_MOCK=true
# FP_SCANNER_SCRIPT=./scripts/scanner.py
